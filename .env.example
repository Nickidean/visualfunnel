# Supabase project credentials.
# Copy to .env.local and fill in for real persistence.
# If these are left unset, the app falls back to browser localStorage so it
# still runs locally without a backend.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Name of the Supabase Storage bucket used for screenshots.
NEXT_PUBLIC_SUPABASE_BUCKET=screenshots
